# ─────────────────────────────────────────────────────────────
# StoryNebula — Environment Variables
# ─────────────────────────────────────────────────────────────
# 1. Copy this file and rename it to:  .env
# 2. Fill in your actual Groq API key below.
# 3. Never commit your real .env file to version control.
# ─────────────────────────────────────────────────────────────

# Your Groq API key — get one free at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Port the server listens on (default: 3000)
PORT=3000

# ── Auto-generation settings ──────────────────────────────────
# The server auto-generates new stories on a built-in loop.
# No external cron tools needed — it runs inside the server itself.

# Set to "false" to disable auto-generation entirely
AUTO_GENERATE=true

# How often to generate a new story (in minutes). Default: 10
# Examples:
#   5  → 1 story every 5 min  = 288 stories/day
#   10 → 1 story every 10 min = 144 stories/day
#   30 → 1 story every 30 min = 48 stories/day
AUTO_INTERVAL_MINUTES=10
